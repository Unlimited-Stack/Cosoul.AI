{
  "name": "@repo/agent",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit-*.spec.ts",
    "test:integration": "vitest run test/integration-*.spec.ts"
  },
  "dependencies": {
    "@repo/core": "*",
    "openai": "^4.104.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "tsup": "^8.0.1",
    "typescript": "~5.5.4",
    "vitest": "^4.0.18"
  }
}
